            {
              "atomType": "GitHubMolecule",
              "x": 0.07275132275132275,
              "y": 0.26111111111111107,
              "uniqueID": "id-877",
              "name": "Isosceles-Triangle---Angle",
              "ioValues": [
                {
                  "name": "Angle",
                  "ioValue": 75
                },
